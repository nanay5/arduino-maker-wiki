---
import troubleshootingData from '../data/troubleshooting.json';

export interface Props {
  parts: string[];
  section: string;
}

const { parts, section } = Astro.props;

// 仅在学生区和高阶区显示
const shouldShow = section === 'students' || section === 'advanced';
if (!shouldShow || !parts || parts.length === 0) {
  return;
}

// 从共享库筛选匹配条目
const matched = troubleshootingData.entries
  .filter((entry) => parts.includes(entry.part))
  .sort((a, b) => (a.severity === 'common' ? -1 : 1));

if (matched.length === 0) {
  return;
}
---

<details class="troubleshooting-block" open>
  <summary>🔧 常见故障排查（{matched.length} 条）</summary>
  <table>
    <thead>
      <tr>
        <th>现象</th>
        <th>可能原因</th>
        <th>解决方法</th>
      </tr>
    </thead>
    <tbody>
      {matched.map((entry) => (
        <tr>
          <td>{entry.symptom}</td>
          <td>{entry.cause}</td>
          <td>{entry.fix}</td>
        </tr>
      ))}
    </tbody>
  </table>
</details>
